# Owner-operated Hermes dashboard image for the optional Render service.
# This is intentionally separate from the Cloud Run API-server image.
FROM nousresearch/hermes-agent@sha256:6ba9f2e4de551c768852f6c7f468ed10d2aec02a921e89722a96b7de507b418a

ENV HERMES_DASHBOARD=1 \
    HERMES_DASHBOARD_HOST=0.0.0.0 \
    HERMES_DASHBOARD_PORT=10000 \
    HERMES_HOME=/opt/data \
    HERMES_WRITE_SAFE_ROOT=/opt/data

EXPOSE 10000

# The upstream image supervises the dashboard alongside the gateway. Never use
# --oneshot or --yolo in an owner dashboard deployment.
CMD ["hermes", "gateway", "run"]
