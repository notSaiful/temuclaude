# OpenRouter API key (primary production backend)
OPENROUTER_API_KEY=your-openrouter-key-here

# AIML backup provider. Keep disabled until AIML has credits.
AIML_API_KEY=your-aiml-key-here
AIML_FALLBACK_ENABLED=false

# Optional direct LLM fallback providers if OpenRouter itself is unavailable.
GROQ_API_KEY=your-groq-key-here
GROQ_FALLBACK_ENABLED=false
DEEPINFRA_API_KEY=your-deepinfra-key-here
DEEPINFRA_FALLBACK_ENABLED=false

# Razorpay Keys (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_PLAN_DEV_ID=your_developer_plan_id_here
RAZORPAY_PLAN_PRO_ID=your_pro_plan_id_here
RAZORPAY_PLAN_ENTERPRISE_ID=your_enterprise_plan_id_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# Supabase Auth
# Enable Email, Google, and GitHub providers in your Supabase dashboard.
# Add http://localhost:3001/auth/callback and your production /auth/callback URL to Supabase Auth Redirect URLs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# Production must use Supabase-backed persistence. Leave false.
# Only set true for temporary diagnostics where losing users/API keys/usage is acceptable.
ALLOW_EPHEMERAL_DB=false

# Modal backend for customer API calls.
# Set TEMUCLAUDE_MODAL_REQUIRED=true in production if the website must fail closed when Modal is unavailable.
TEMUCLAUDE_MODAL_URL=https://your-modal-app-url.modal.run
TEMUCLAUDE_MASTER_KEY=change-this-to-a-secure-random-string
TEMUCLAUDE_MODAL_REQUIRED=false

# JWT secret for auth
JWT_SECRET=change-this-to-a-secure-random-string
