# Temuclaude Environment Variables
# Copy this file to .env and fill in your values

# LiteLLM proxy master key (generate with: openssl rand -hex 32)
TEMUCLAUDE_MASTER_KEY=your-secret-key-here
TEMUCLAUDE_API_KEY=generate-a-separate-long-random-secret
TEMUCLAUDE_CORS_ORIGINS=https://temuclaude.com
# Required only for private Hasan machine-control and deployment-queue routes.
# Never expose this value to the browser.
TEMUCLAUDE_INTERNAL_ADMIN_KEY=generate-a-separate-long-random-secret

# OpenRouter API key (primary production backend — scales to thousands of users)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Supabase Auth for the website
# Enable Email, Google, and GitHub providers in Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# Isolated Playground previews. Keep this server-only and never prefix it with NEXT_PUBLIC_.
E2B_API_KEY=
GITHUB_WEBHOOK_SECRET=generate-a-long-random-webhook-secret
VERCEL_TOKEN=
VERCEL_TEAM_ID=
APP_AUTH_SECRET=generate-a-long-random-secret
OTP_SECRET=generate-a-different-long-random-secret
# Production must use Supabase-backed persistence. Leave false.
# Only set true for temporary diagnostics where losing users/API keys/usage is acceptable.
ALLOW_EPHEMERAL_DB=false

# Production email (Resend is the default OTP and transactional provider).
# Verify temuclaude.com in Resend, then create a sending-only API key.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="TemuClaude <hello@temuclaude.com>"
# Optional Hostinger mailbox settings for inbound mail or a future SMTP fallback.
HOSTINGER_API_TOKEN=your-hostinger-api-token
HOSTINGER_EMAIL_USER=hello@temuclaude.com
HOSTINGER_EMAIL_PASSWORD=your-hostinger-mailbox-or-app-password
HOSTINGER_SMTP_HOST=smtp.hostinger.com
HOSTINGER_SMTP_PORT=465
HOSTINGER_SMTP_SECURE=true
HOSTINGER_IMAP_HOST=imap.hostinger.com
HOSTINGER_IMAP_PORT=993
HOSTINGER_IMAP_SECURE=true
INBOUND_EMAIL_WEBHOOK_SECRET=generate-a-long-random-webhook-secret

# Modal backend used by the website gateway.
TEMUCLAUDE_MODAL_URL=https://your-modal-app-url.modal.run
TEMUCLAUDE_MODAL_REQUIRED=false

# Hosted checkout is parked for the current production launch.
# Keep false until a payment provider is fully configured and tested.
NEXT_PUBLIC_BILLING_CHECKOUT_ENABLED=false

# Optional Razorpay checkout/webhook settings for a future billing rollout.
# RAZORPAY_KEY_ID=your_key_id_here
# RAZORPAY_KEY_SECRET=your_key_secret_here
# RAZORPAY_PLAN_DEV_ID=your_developer_plan_id_here
# RAZORPAY_PLAN_PRO_ID=your_pro_plan_id_here
# RAZORPAY_PLAN_MAX_ID=your_max_plan_id_here
# RAZORPAY_PLAN_ENTERPRISE_ID=your_enterprise_plan_id_here

# ai/ml API key (emergency fallback — used if OpenRouter fails)
# Get one at: https://aimlapi.com/app/billing/
AIML_API_KEY=your-aiml-key-here
# Keep false until AIML has credits; set true after funding the account.
AIML_FALLBACK_ENABLED=false
# Live playground media jobs are opt-in and require the Supabase media-jobs
# migration plus an AIML key. Keep Free excluded until media billing is enabled.
MEDIA_ENABLED_PLANS=developer,pro,max,enterprise
AIML_IMAGE_MODEL=alibaba/z-image-turbo
AIML_VIDEO_MODEL=minimax/hailuo-2.3
AIML_TTS_MODEL=openai/tts-1
AIML_MUSIC_MODEL=minimax/music-2.0

# Optional direct LLM fallback providers if OpenRouter itself is unavailable.
# Keep disabled unless you have funded/configured these accounts.
GROQ_API_KEY=your-groq-key-here
GROQ_FALLBACK_ENABLED=false
DEEPINFRA_API_KEY=your-deepinfra-key-here
DEEPINFRA_FALLBACK_ENABLED=false

# Premium role routes (optional). These are never selected unless their
# credentials are configured; absent credentials resolve to the open-model
# stack. Use these only after shadow evaluation proves their task-specific win.
OPENAI_API_KEY=your-openai-key-here
XAI_API_KEY=your-xai-key-here
GOOGLE_API_KEY=your-google-ai-key-here
# GPT-5.6 Terra is an emergency-only route. Keep false until the preview is
# available to this organization and the promotion gate approves it.
TEMUCLAUDE_ENABLE_TERRA_FALLBACK=false

# Optional: HuggingFace token (for HLE benchmark dataset)
# Register at: https://huggingface.co/datasets/cais/hle
# HF_TOKEN=your-hf-token-here
