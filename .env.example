# Temuclaude Environment Variables
# Copy this file to .env and fill in your values

# LiteLLM proxy master key (generate with: openssl rand -hex 32)
TEMUCLAUDE_MASTER_KEY=your-secret-key-here

# OpenRouter API key (primary production backend — scales to thousands of users)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Supabase Auth for the website
# Enable Email, Google, and GitHub providers in Supabase Auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key
# Production must use Supabase-backed persistence. Leave false.
# Only set true for temporary diagnostics where losing users/API keys/usage is acceptable.
ALLOW_EPHEMERAL_DB=false

# Modal backend used by the website gateway.
TEMUCLAUDE_MODAL_URL=https://your-modal-app-url.modal.run
TEMUCLAUDE_MODAL_REQUIRED=false

# ai/ml API key (emergency fallback — used if OpenRouter fails)
# Get one at: https://aimlapi.com/app/billing/
AIML_API_KEY=your-aiml-key-here
# Keep false until AIML has credits; set true after funding the account.
AIML_FALLBACK_ENABLED=false

# Optional direct LLM fallback providers if OpenRouter itself is unavailable.
# Keep disabled unless you have funded/configured these accounts.
GROQ_API_KEY=your-groq-key-here
GROQ_FALLBACK_ENABLED=false
DEEPINFRA_API_KEY=your-deepinfra-key-here
DEEPINFRA_FALLBACK_ENABLED=false

# Optional: HuggingFace token (for HLE benchmark dataset)
# Register at: https://huggingface.co/datasets/cais/hle
# HF_TOKEN=your-hf-token-here
